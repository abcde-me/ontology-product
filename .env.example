# AI 本体工作台 - DeepSeek Pro 大模型
# @see https://api-docs.deepseek.com/zh-cn/
REACT_APP_AI_WORKBENCH_LLM_API_NAME=aiontosys
REACT_APP_AI_WORKBENCH_LLM_API_KEY=
REACT_APP_AI_WORKBENCH_LLM_MODEL=deepseek-v4-pro
# Vercel 部署：留空或设为 /deepseek-api（经 Serverless 代理，避免 CORS）
# 直连 DeepSeek（可能遇 CORS）：https://api.deepseek.com
REACT_APP_AI_WORKBENCH_LLM_BASE_URL=/deepseek-api

# DeepSeek Embedding（本体字段向量化 / 相似性检索）
REACT_APP_EMBEDDING_API_NAME=embedding
REACT_APP_EMBEDDING_API_KEY=
REACT_APP_EMBEDDING_MODEL=embedding
REACT_APP_EMBEDDING_BASE_URL=/deepseek-api
# REACT_APP_EMBEDDING_DIMENSION=1536

# 开发环境：GetProjOrg 无数据时，可配置真实后端项目 ID（向管理员获取）
# REACT_APP_DEV_REAL_ORG_ID=your-org-id
# REACT_APP_DEV_REAL_PROJECT_ID=your-project-id
# 分片上传附件所需：项目绑定的文件存储 ID（与项目 ID 一并向管理员获取）
# REACT_APP_DEV_REAL_FS_ID=your-filesystem-id

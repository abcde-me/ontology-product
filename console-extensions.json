[
  {
    "type": "console.page/route",
    "properties": {
      "exact": true,
      "path": [
        "/tenant/compute/onto/login",
        "/tenant/compute/onto/userinfo",
        "/tenant/compute/onto/home",
        "/tenant/compute/onto/ontologyScene"
      ],
      "component": {
        "$codeRef": "AdminLayout.default"
      }
    }
  },
  {
    "type": "console.header/config",
    "properties": {
      "id": "ontology-platform",
      "ssoType": "false",
      "blacklist": [
        "/tenant/compute/onto/login",
        "/tenant/compute/onto/userinfo"
      ]
    }
  },
  {
    "type": "console.redux-reducer",
    "properties": {
      "scope": "consolePluginnoto",
      "reducer": {
        "$codeRef": "reduxReducer"
      }
    }
  }
]

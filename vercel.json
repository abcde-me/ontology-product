{
  "installCommand": "yarn install --frozen-lockfile",
  "buildCommand": "cross-env NODE_OPTIONS=--max-old-space-size=4096 yarn build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/deepseek-api/(.*)",
      "destination": "/api/deepseek-proxy?path=$1"
    },
    {
      "source": "/onto/static/(.*)",
      "destination": "/static/$1"
    },
    {
      "source": "/onto/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/onto",
      "destination": "/index.html"
    },
    {
      "source": "/onto/(.*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/onto/",
      "permanent": false
    }
  ]
}

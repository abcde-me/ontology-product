{
  "name": "modaforge-front",
  "version": "0.1.1",
  "private": true,
  "description": "CCXD Pro",
  "scripts": {
    "clean": "rimraf dist build",
    "start": "yarn clean && node --max-old-space-size=4096 ./scripts/start",
    "dev": "cross-env PORT=9030 GENERATE_SOURCEMAP=false SINGLE_APP=true yarn start",
    "build": "yarn clean && cross-env NODE_ENV=production GENERATE_SOURCEMAP=false node ./scripts/build",
    "eslint": "eslint src/ --ext .ts,.tsx,.js,.jsx --cache",
    "eslint:fix": "eslint src/ --ext .ts,.tsx,.js,.jsx --fix --cache --fix",
    "stylelint": "stylelint \"src/**/*.less\" \"src/**/*.scss\" \"src/**/*.css\" --fix --cache",
    "test": "LANG=en_US.UTF-8 jest",
    "pre-commit": "lint-staged",
    "prepare": "husky install",
    "i18n": "i18next \"src/**/*.{js,jsx,ts,tsx}\" [-oc] -c i18next-parser.config.js",
    "ts-node": "ts-node -O '{\"module\":\"commonjs\"}'",
    "start:http-server": "yarn build:cp && ./node_modules/.bin/http-server ./dist -p 9001",
    "i18n-parse": "node --experimental-modules ./scripts/tools/i18n/index.js",
    "test-cypress-modaforge-front": "cd integration-tests-cypress && cypress open --env ccos=true",
    "test-cypress-modaforge-front-headless": "cd integration-tests-cypress && cypress run --env ccos=true --browser ${BRIDGE_E2E_BROWSER_NAME:=chrome} --headless",
    "cypress-merge": "mochawesome-merge ./gui_test_screenshots/cypress_report*.json > ./gui_test_screenshots/cypress.json",
    "cypress-generate": "marge -o ./gui_test_screenshots/ -f cypress-report -t 'Ccos Console Cypress Test Results' -p 'Ccos Cypress Test Results' --showPassed false --assetsDir ./gui_test_screenshots/cypress/assets ./gui_test_screenshots/cypress.json",
    "cypress-postreport": "yarn cypress-merge && yarn cypress-generate"
  },
